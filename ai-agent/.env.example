# ==============================================================================
# Configuration pour l'agent de remédiation IA - Hackathon OVHcloud x Ynov
# ==============================================================================

# --- OVHcloud AI Endpoints Configuration ---
# Obtenez votre token depuis le manager OVHcloud (Public Cloud > AI Endpoints > API Keys)
OVH_AI_ENDPOINTS_ACCESS_TOKEN="votre_token_ici"

# Base URL de l'API OVHcloud AI Endpoints
OVH_AI_ENDPOINTS_BASE_URL="https://oai.endpoints.kepler.ai.cloud.ovh.net/v1"

# Modèle d'IA à utiliser pour l'analyse et la remédiation.
# Exemples : Mistral-7B-Instruct-v0.3, Llama-3.1-8B-Instruct, tag:llama:latest
OVH_AI_ENDPOINTS_MODEL="Mistral-7B-Instruct-v0.3"

# --- Configuration Git / GitHub ---
# Token d'accès personnel GitHub (PAT) avec les scopes 'repo' pour pouvoir push et créer des PR
GITHUB_TOKEN="ghp_votre_token_github"

# Dépôt GitHub cible pour les manifestes (ex: "utilisateur/YnovXOVH")
GITHUB_REPOSITORY="username/YnovXOVH"

# Branche de base du dépôt (souvent 'main' ou 'master')
GIT_BASE_BRANCH="main"

# Chemin vers le dossier local contenant les manifestes à modifier (par défaut, la racine du projet ou un sous-dossier)
MANIFESTS_DIR="../"
